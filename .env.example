# ==========================================
# Vendra Template Environment Configuration
# ==========================================

# --- Database Setup (MySQL) ---
MYSQL_PORT=3306
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=vendra_db
AUTH_DB_NAME=auth_db
NOTIFICATION_DB_NAME=notification_db

# --- Spring Config Server Profile ---
SPRING_PROFILES_ACTIVE=native

# --- Service Exposed Ports ---
CONFIG_SERVER_PORT=8888
DISCOVERY_SERVER_PORT=8761
API_GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
NOTIFICATION_SERVICE_PORT=8082

# --- Discovery Registry Configuration ---
# Set to 'localhost' when running microservices locally on your host machine
EUREKA_HOSTNAME=discovery-server

# --- Microservice Links/URLs ---
# Set these to 'localhost' based URLs when running locally outside Docker
CONFIG_SERVER_URL=http://config-server:8888
EUREKA_SERVER_URL=http://discovery-server:8761/eureka/

# --- Kafka Broker configuration ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# --- Distributed Tracing (Zipkin) ---
# Use the zipkin container name inside docker-compose; http://localhost:9411/... when running locally.
ZIPKIN_ENDPOINT=http://zipkin:9411/api/v2/spans
